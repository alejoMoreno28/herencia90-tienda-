{
  "outputDirectory": "web",
  "headers": [
    {
      "source": "/(.*).html",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/categorias/:slug", "destination": "/categorias/:slug.html" },
    { "source": "/ciudades/:slug", "destination": "/ciudades/:slug.html" },
    { "source": "/camisetas/:slug", "destination": "/camisetas/:slug.html" },
    { "source": "/catalogo", "destination": "/catalogo.html" },
    { "source": "/admin", "destination": "/admin.html" },
    { "source": "/login", "destination": "/login.html" },
    { "source": "/preventa", "destination": "/preventa.html" },
    { "source": "/nosotros", "destination": "/nosotros.html" },
    { "source": "/preguntas-frecuentes", "destination": "/preguntas-frecuentes.html" }
  ]
}
